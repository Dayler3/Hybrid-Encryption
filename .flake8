[flake8]
max-line-length = 120
extend-ignore =
    E203,
    W503,
    E266,
    E731,
    F401

# Исключение служебных и генерируемых файлов
exclude =
    .git,
    __pycache__,
    venv,
    env,

# Игнорируем конкретные файлы/паттерны
per-file-ignores =
    src/__init__.py: F401
    main.py: E501  # Длинные строки могут быть оправданы
    requirements.txt: ALL
    README.md: ALL
    LICENSE: ALL

# Дополнительные настройки
statistics = True
show-source = True
verbose = 0
